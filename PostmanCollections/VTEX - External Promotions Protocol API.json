              },
              {
                "disabled": false,
                "description": {
                  "content": "(Required) HTTP Client Negotiation _Accept_ Header. Indicates the types of responses the client can understand.",
                  "type": "text/plain"
                },
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"099823581-1\",\n  \"type\": \"NewOrder\",\n  \"promotionUsages\": [\n    {\n      \"promotionId\": \"promo-1\",\n      \"discount\": 0.75,\n      \"couponCode\": \"coupon-code-1\"\n    }\n  ]\n}",
