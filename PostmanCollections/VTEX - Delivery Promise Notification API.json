  "info": {
    "_postman_id": "d8b5460b-4957-4678-8dea-b88f5025e89c",
    "name": "Delivery Promise Notification API",
    "version": {
      "raw": "1.0.0",
      "major": 1,
      "minor": 0,
      "patch": 0,
      "prerelease": [],
      "build": [],
      "string": "1.0.0"
