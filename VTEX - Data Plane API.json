{
  "openapi": "3.0.0",
  "info": {
    "title": "Content Platform Data Plane API",
    "version": "1.0.0",
    "description": "Content Platform Data Plane API provides read access to published content entries for storefront and runtime integrations.\n\n## Authentication\n\nThis API does not enforce authentication in the service route handlers.\n\n## Permissions\n\nNo License Manager resource is required to use the endpoints documented in this API.\n\n## Index\n\n### Entry\n- ``GET`` [List entries by content type](https://developers.vtex.com/docs/api-reference/data-plane-api#get-/api/content-platform/data/-account-/-storeId-/-contentTypeId-/entries)\n- ``GET`` [Get entry by ID](https://developers.vtex.com/docs/api-reference/data-plane-api#get-/api/content-platform/data/-account-/-storeId-/-contentTypeId-/entries/-id-)\n- ``GET`` [Get entry by slug](https://developers.vtex.com/docs/api-reference/data-plane-api#get-/api/content-platform/data/-account-/-storeId-/-contentTypeId-/entries/slug/-slugPath-)\n\n## Common Parameters\n\n- `Accept`: Media type expected in the response.\n- `If-None-Match`: ETag validator used for conditional requests.\n\n## Best Practices\n\n- Use `If-None-Match` with ETags to reduce payload transfer when content has not changed.\n- Prefer slug-based retrieval for storefront navigation paths.\n- Use the `locale` query parameter to request locale-aware content resolution."
  },
  "servers": [
    {
      "url": "https://{accountName}.{environment}.com.br",
      "variables": {
        "accountName": {
          "default": "apiexamples",
          "description": "Name of the VTEX account. Used as part of the URL."
        },
        "environment": {
          "enum": [
            "vtexcommercestable"
          ],
          "default": "vtexcommercestable",
          "description": "Environment to use. Used as part of the URL."
        }
      }
    }
  ],
  "paths": {
    "/api/content-platform/data/{account}/{storeId}/{contentTypeId}/entries": {
      "get": {
        "tags": [
          "Entry"
        ],
        "summary": "List entries by content type",
        "description": "Lists entries for a content type and store, with optional sorting, pagination cursor, and locale-aware content resolution.\\r\\n\\r\\n## Permissions\\r\\n\\r\\nThis endpoint does not require [authentication](https://developers.vtex.com/docs/guides/authentication) or [permissions](https://help.vtex.com/en/tutorial/license-manager-resources--3q6ztrC8YynQf6rdc6euk3).",
        "parameters": [
          {
            "$ref": "#/components/parameters/Account"
          },
          {
            "$ref": "#/components/parameters/StoreId"
          },
          {
            "$ref": "#/components/parameters/ContentTypeId"
          },
          {
            "$ref": "#/components/parameters/Sort"
          },
          {
            "$ref": "#/components/parameters/Order"
          },
          {
            "$ref": "#/components/parameters/Scroll"
          },
          {
            "$ref": "#/components/parameters/Content"
          },
          {
            "$ref": "#/components/parameters/Locale"
          },
          {
            "$ref": "#/components/parameters/If-None-Match"
          },
          {
            "$ref": "#/components/parameters/Accept"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListEntriesResponse"
                },
                "example": {
                  "entries": [
                    {
                      "id": "3f1d5e18-0c78-4310-8d93-9499f2f5d18c",
                      "name": "home-banner",
                      "createdAt": "2026-04-12T09:10:11.000Z",
                      "updatedAt": "2026-04-14T08:35:00.000Z",
                      "search_keywords": [
                        "home",
                        "banner"
                      ],
                      "createdBy": "content.manager@company.com"
                    }
                  ],
                  "scroll": "eyJzb3J0IjoidXBkYXRlZEF0Iiwib3JkZXIiOiJkZXNjIiwibGFzdElkIjoiM2YxZDVlMTgtMGM3OC00MzEwLThkOTMtOTQ5OWYyZjVkMThjIn0="
                }
              }
            }
          },
          "304": {
            "description": "Not Modified"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                },
                "example": {
                  "error": "Invalid request data",
                  "code": "FASTIFY_VALIDATION_ERROR"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                },
                "example": {
                  "error": "Failed to list entries",
                  "code": "ENTRY_LIST_ERROR"
                }
              }
            }
          }
        }
      }
    },
    "/api/content-platform/data/{account}/{storeId}/{contentTypeId}/entries/{id}": {
      "get": {
        "tags": [
          "Entry"
        ],
        "summary": "Get entry by ID",
        "description": "Retrieves the latest published entry version by entry identifier and resolves locale content when requested.\\r\\n\\r\\n## Permissions\\r\\n\\r\\nThis endpoint does not require [authentication](https://developers.vtex.com/docs/guides/authentication) or [permissions](https://help.vtex.com/en/tutorial/license-manager-resources--3q6ztrC8YynQf6rdc6euk3).",
        "parameters": [
          {
            "$ref": "#/components/parameters/Account"
          },
          {
            "$ref": "#/components/parameters/StoreId"
          },
          {
            "$ref": "#/components/parameters/ContentTypeId"
          },
          {
            "$ref": "#/components/parameters/EntryId"
          },
          {
            "$ref": "#/components/parameters/Branch"
          },
          {
            "$ref": "#/components/parameters/Contexts"
          },
          {
            "$ref": "#/components/parameters/Locale"
          },
          {
            "$ref": "#/components/parameters/If-None-Match"
          },
          {
            "$ref": "#/components/parameters/Accept"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DynamicEntryResponse"
                },
                "example": {
                  "id": "3f1d5e18-0c78-4310-8d93-9499f2f5d18c",
                  "title": "Spring Campaign",
                  "slug": "/spring-campaign",
                  "seo": {
                    "title": "Spring Campaign",
                    "description": "Landing page for spring campaign."
                  },
                  "locale_metadata": {
                    "locale": "en-US",
                    "language": "English",
                    "country": "United States"
                  }
                }
              }
            }
          },
          "304": {
            "description": "Not Modified"
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                },
                "example": {
                  "error": "Route not found"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                },
                "example": {
                  "error": "Failed to retrieve entry",
                  "code": "ENTRY_RETRIEVAL_ERROR"
                }
              }
            }
          }
        }
      }
    },
    "/api/content-platform/data/{account}/{storeId}/{contentTypeId}/entries/slug/{slugPath}": {
      "get": {
        "tags": [
          "Entry"
        ],
        "summary": "Get entry by slug",
        "description": "Retrieves the latest published entry version by slug path and resolves locale-specific content when requested.\\r\\n\\r\\n## Permissions\\r\\n\\r\\nThis endpoint does not require [authentication](https://developers.vtex.com/docs/guides/authentication) or [permissions](https://help.vtex.com/en/tutorial/license-manager-resources--3q6ztrC8YynQf6rdc6euk3).",
        "parameters": [
          {
            "$ref": "#/components/parameters/Account"
          },
          {
            "$ref": "#/components/parameters/StoreId"
          },
          {
            "$ref": "#/components/parameters/ContentTypeId"
          },
          {
            "$ref": "#/components/parameters/SlugPath"
          },
          {
            "$ref": "#/components/parameters/Branch"
          },
          {
            "$ref": "#/components/parameters/Contexts"
          },
          {
            "$ref": "#/components/parameters/Locale"
          },
          {
            "$ref": "#/components/parameters/If-None-Match"
          },
          {
            "$ref": "#/components/parameters/Accept"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DynamicEntryResponse"
                },
                "example": {
                  "id": "3f1d5e18-0c78-4310-8d93-9499f2f5d18c",
                  "title": "Spring Campaign",
                  "slug": "/spring-campaign",
                  "locale_metadata": {
                    "locale": "en-US",
                    "language": "English",
                    "country": "United States"
                  }
                }
              }
            }
          },
          "304": {
            "description": "Not Modified"
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                },
                "example": {
                  "error": "Invalid slug parameter",
                  "code": "INVALID_SLUG"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                },
                "example": {
                  "error": "Route not found"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                },
                "example": {
                  "error": "Failed to retrieve entry by slug",
                  "code": "ENTRY_SLUG_RETRIEVAL_ERROR"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "Accept": {
        "name": "Accept",
        "in": "header",
        "description": "Expected response media type.",
        "required": true,
        "schema": {
          "type": "string",
          "example": "application/json"
        }
      },
      "If-None-Match": {
        "name": "If-None-Match",
        "in": "header",
        "description": "ETag value used for conditional requests.",
        "required": false,
        "schema": {
          "type": "string",
          "example": "\"f48442f3f4f53f4d\""
        }
      },
      "Account": {
        "name": "account",
        "in": "path",
        "description": "VTEX account name.",
        "required": true,
        "schema": {
          "type": "string",
          "example": "apiexamples"
        }
      },
      "StoreId": {
        "name": "storeId",
        "in": "path",
        "description": "Store identifier.",
        "required": true,
        "schema": {
          "type": "string",
          "example": "store-1"
        }
      },
      "ContentTypeId": {
        "name": "contentTypeId",
        "in": "path",
        "description": "Content type identifier.",
        "required": true,
        "schema": {
          "type": "string",
          "example": "landing-page"
        }
      },
      "EntryId": {
        "name": "id",
        "in": "path",
        "description": "Entry identifier.",
        "required": true,
        "schema": {
          "type": "string",
          "example": "3f1d5e18-0c78-4310-8d93-9499f2f5d18c"
        }
      },
      "SlugPath": {
        "name": "slugPath",
        "in": "path",
        "description": "Entry slug path value.",
        "required": true,
        "schema": {
          "type": "string",
          "example": "spring-campaign"
        }
      },
      "Sort": {
        "name": "sort",
        "in": "query",
        "description": "Sort field name.",
        "required": false,
        "schema": {
          "type": "string",
          "example": "updatedAt"
        }
      },
      "Order": {
        "name": "order",
        "in": "query",
        "description": "Sort order direction.",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "asc",
            "desc"
          ],
          "example": "desc"
        }
      },
      "Scroll": {
        "name": "scroll",
        "in": "query",
        "description": "Cursor token for pagination.",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "Content": {
        "name": "content",
        "in": "query",
        "description": "Content expansion mode. Use `all` to include blob content.",
        "required": false,
        "schema": {
          "type": "string",
          "example": "all"
        }
      },
      "Locale": {
        "name": "locale",
        "in": "query",
        "description": "Locale code used to resolve localized content.",
        "required": false,
        "schema": {
          "type": "string",
          "nullable": true,
          "example": "en-US"
        }
      },
      "Branch": {
        "name": "branch",
        "in": "query",
        "description": "Branch identifier used for retrieval. Defaults to `main`.",
        "required": false,
        "schema": {
          "type": "string",
          "default": "main",
          "nullable": true
        }
      },
      "Contexts": {
        "name": "contexts",
        "in": "query",
        "description": "Context values for conditional content resolution.",
        "required": false,
        "schema": {
          "type": "string",
          "nullable": true
        }
      }
    },
    "schemas": {
      "StandardErrorResponse": {
        "type": "object",
        "description": "Standard error payload returned by data-plane handlers.",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error message explaining the failure."
          },
          "code": {
            "type": "string",
            "description": "Optional machine-readable error code."
          }
        },
        "required": [
          "error"
        ]
      },
      "EntrySummary": {
        "type": "object",
        "description": "Summary representation of an entry in list responses.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Entry unique identifier."
          },
          "name": {
            "type": "string",
            "description": "Entry display name."
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Entry creation timestamp."
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Entry last update timestamp."
          },
          "search_keywords": {
            "type": "array",
            "description": "Keywords used for search and slug matching.",
            "items": {
              "type": "string",
              "description": "Keyword value."
            },
            "nullable": true
          },
          "createdBy": {
            "type": "string",
            "description": "Creator identifier.",
            "nullable": true
          },
          "blobContent": {
            "type": "object",
            "description": "Entry content payload when `content=all` is requested.",
            "additionalProperties": true,
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "createdAt",
          "updatedAt"
        ]
      },
      "ListEntriesResponse": {
        "type": "object",
        "description": "Response containing entry list and optional cursor.",
        "properties": {
          "entries": {
            "type": "array",
            "description": "List of entries matching the filters.",
            "items": {
              "$ref": "#/components/schemas/EntrySummary"
            }
          },
          "scroll": {
            "type": "string",
            "description": "Pagination cursor for the next page.",
            "nullable": true
          },
          "locale_metadata": {
            "$ref": "#/components/schemas/LocaleMetadata"
          }
        },
        "required": [
          "entries"
        ]
      },
      "LocaleMetadata": {
        "type": "object",
        "description": "Locale metadata returned when locale resolution is applied.",
        "additionalProperties": true,
        "nullable": true
      },
      "DynamicEntryResponse": {
        "type": "object",
        "description": "Resolved entry payload with dynamic content fields.",
        "additionalProperties": true
      }
    }
  },
  "security": [],
  "tags": [
    {
      "name": "Entry",
      "description": "Operations for listing and retrieving content entries."
    }
  ]
}
